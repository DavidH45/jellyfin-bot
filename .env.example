# ── Discord ───────────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Application (client) ID from the Developer Portal
DISCORD_CLIENT_ID=

# Guild (server) ID — leave empty to register commands globally
GUILD_ID=

# Your Discord user ID (right-click yourself → Copy User ID)
OWNER_ID=

# ── Jellyfin ──────────────────────────────────────────────────────────────────
# Full URL to your Jellyfin instance, e.g. https://jellyfin.example.com
JELLYFIN_URL=

# Admin API key from Jellyfin → Dashboard → API Keys
JELLYFIN_API_KEY=

# ── Jellyseerr ────────────────────────────────────────────────────────────────
# Full URL to your Jellyseerr instance, e.g. https://jellyseerr.example.com
JELLYSEERR_URL=

# API key from Jellyseerr → Settings → General
JELLYSEERR_API_KEY=

# ── Bot settings ──────────────────────────────────────────────────────────────
# Discord Role ID to assign to active subscribers
SUBSCRIBER_ROLE_ID=

# Discord channel ID where audit log messages are posted
AUDIT_LOG_CHANNEL_ID=
